function BlobUtility:GetClosestOrb()
	if not BlobUtility:AntiCheatBypassRunning() then
		BlobUtility:InitializeAntiCheatBypass()
	end

	local closestOrb = nil
	for _, v in pairs(BlobUtility:GetFoods()) do
		if not closestOrb then
			closestOrb = v
		else
			if BlobUtility:GetDistance(HumanoidRootPart.Position, v.Position) < BlobUtility:GetDistance(HumanoidRootPart.Position, closestOrb.Position) then
				closestOrb = v
			end
		end
	end
	return closestOrb
end

function BlobUtility:IsOrbSafe(orbPos)
	local playersInPath = BlobUtility:isPlayerInPath(HumanoidRootPart.Position, orbPos)
	local myMass = BlobUtility:GetMass(BlobUtility:GetData(Player.Name))

	for _, player in pairs(playersInPath) do
		if player.Name ~= Player.Name then
			local data = BlobUtility:GetData(player.Name)
			local mass = data and BlobUtility:GetMass(data)

			if mass and myMass and mass > myMass then
				return false
			end
		end
	end

	return true
end

function BlobUtility:GetMostValuableOrb()
	if not BlobUtility:AntiCheatBypassRunning() then
		BlobUtility:InitializeAntiCheatBypass()
	end

	local bestOrb = nil
	local myMass = BlobUtility:GetMass(BlobUtility:GetData(Player.Name))

	for _, v in pairs(BlobUtility:GetFoods()) do
		local orbMass = BlobUtility:GetMassFromOrb(v)

		if orbMass and myMass and orbMass < myMass then
			if BlobUtility:IsOrbSafe(v.Position) then
				if not bestOrb or orbMass > BlobUtility:GetMassFromOrb(bestOrb) then
					bestOrb = v
				end
			end
		end
	end

	return bestOrb
end

