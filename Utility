local con -- to stop memory leak

local function runchar(char)
	Character = char
	HumanoidRootPart = char:WaitForChild("HumanoidRootPart")
	char.ChildAdded:Connect(function(child)
		if child.Name == "Animate" then
			if child:GetAttribute(".") then
				local player = game.Players.LocalPlayer
				local runService = game:GetService("RunService")
				local humanoid = Character:WaitForChild("Humanoid")

				repeat
					task.wait(0.1)
				until player and player.Character and player.Character:FindFirstChild("HumanoidRootPart")
				local stats = game.ReplicatedStorage.Data:WaitForChild(player.Name):WaitForChild("Stats")

				humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
				humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)

				local UIS = game:GetService("UserInputService")

				local function getInput()
					local forward = (UIS:IsKeyDown(Enum.KeyCode.W) and 1 or 0) - (UIS:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
					local right = (UIS:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UIS:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
					local input = Vector3.new(right, 0, forward)

					if input.Magnitude > 0 then
						input = input.Unit
					end

					return input
				end

				if con then
					con:Disconnect()
					con = nil
				end

				con = runService.RenderStepped:Connect(function()
					local character = player.Character
					if not character then return end

					local root = character:FindFirstChild("HumanoidRootPart")
					if not root then return end

					local mass = stats:WaitForChild("Mass").Value
					local speed = Speed
					
					if speed == -1 then
						local data = BlobUtility:GetData(game.Players.LocalPlayer.Name)
						if not data then return end
						
						local Mass = BlobUtility:GetMass(data)
						if not Mass then return end
						
						Speed = 0.85 ^ math.log10(Mass) * 40
					end

					if stats:WaitForChild("x2Speed").Value > 0 then
						speed = speed * 2
					end
					
					humanoid.WalkSpeed = speed

					local input = getInput()

					if input.Magnitude > 0 then
						local cam = workspace.CurrentCamera.CFrame
						local move = cam.LookVector * input.Z + cam.RightVector * input.X
						move = Vector3.new(move.X, 0, move.Z)

						if move.Magnitude > 0 then
							move = move.Unit * speed
						end

						local rayParams = RaycastParams.new()
						rayParams.FilterDescendantsInstances = {character}
						rayParams.FilterType = Enum.RaycastFilterType.Exclude

						local ray = workspace:Raycast(root.Position, Vector3.new(0, -3, 0), rayParams)

						if ray then
							local normal = ray.Normal
							move = move - normal * move:Dot(normal)
						end

						root.AssemblyLinearVelocity = Vector3.new(
							move.X,
							root.AssemblyLinearVelocity.Y,
							move.Z
						)
					else
						root.AssemblyLinearVelocity = Vector3.new(
							0,
							root.AssemblyLinearVelocity.Y,
							0
						)
					end
				end)
			end
		end
	end)
end

