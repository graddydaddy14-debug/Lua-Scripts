function BlobUtility:isPlayerInPath(startLine: Vector3, endLine: Vector3) -- made by chatgpt because I don't know fuck all about math in lua
	startLine = Vector3.new(startLine.X, 0, startLine.Z)
	endLine = Vector3.new(endLine.X, 0, endLine.Z)

	local playersInPath = {}
	local direction = (endLine - startLine)
	local distance = direction.Magnitude

	if distance == 0 then return playersInPath end
	direction = direction.Unit

	for _, v in pairs(Players:GetChildren()) do
		local rootPart = v:FindFirstChild("HumanoidRootPart")
		if rootPart then
			local root = Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)

			local t = (root - startLine):Dot(direction) / distance
			local point = startLine + direction * math.clamp(t, 0, 1) * distance

			local distFromLine = (root - point).Magnitude
			if distFromLine <= 10 then
				table.insert(playersInPath, v)
			end
		end
	end

	return playersInPath
end

