function BlobUtility:GetMassFromOrb(orb : Part)
	local ui = orb:FindFirstChild("UI")
	if not ui then return 0 end
	local mass = ui:FindFirstChild("Mass")
	if not mass then return 0 end
	return tonumber(mass.Text) or 0
end

