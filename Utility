function BlobUtility:AntiCheatBypassRunning()
	if Character then
		local animate = Character:FindFirstChild("Animate")
		if animate then
			local attribute = animate:GetAttribute(".")
			if attribute then
				return true
			end
		end
	end
	return false
end

function BlobUtility:InitializeAntiCheatBypass()
	if BlobUtility:AntiCheatBypassRunning() then return end

	local AntiCheat = Character:FindFirstChild("Animate")
	if AntiCheat then
		if AntiCheat:GetAttribute(".") then
			return
		end

		AntiCheat:Destroy()
	end

	local animate = Instance.new("LocalScript")
	animate.Name = "Animate"
	animate:SetAttribute(".", ".")
	animate.Parent = Character
	-- Come back to this later... this is to bypass shitty anti cheat
end


