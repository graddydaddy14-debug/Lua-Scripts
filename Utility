end

function BlobUtility:IsPlayerSafe(targetPlayer)
	local targetRoot = targetPlayer:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return false end

	local targetData = BlobUtility:GetData(targetPlayer.Name)
	local targetMass = targetData and BlobUtility:GetMass(targetData)
	if not targetMass then return false end

	for _, other in pairs(Players:GetChildren()) do
		if other.Name ~= Player.Name and other.Name ~= targetPlayer.Name then
			local otherRoot = other:FindFirstChild("HumanoidRootPart")
			if otherRoot then
				local otherData = BlobUtility:GetData(other.Name)
				local otherMass = otherData and BlobUtility:GetMass(otherData)

				if otherMass and otherMass > targetMass then
					local dist = (otherRoot.Position - targetRoot.Position).Magnitude
					if dist < 15 then
						return false
					end
				end
			end
		end
	end

	return true
end

