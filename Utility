function BlobUtility:GetNearestPlayer(pos)
	local nearestPlayer = nil
	local nearestDistance = math.huge

	local myMass = BlobUtility:GetMass(BlobUtility:GetData(Player.Name))
	if not myMass then return nil end

	for _, player in pairs(Players:GetChildren()) do
		if player.Name ~= Player.Name and player:FindFirstChild("HumanoidRootPart") then

			local data = BlobUtility:GetData(player.Name)
			local mass = data and BlobUtility:GetMass(data)
			if mass and mass < myMass and mass > 500 and not Player:IsFriendsWithAsync(BlobUtility:GetPlayerFromCharacter(player).UserId) and not BlobUtility:isDead(Player.Name) and not BlobUtility:isDead(player.Name) then
				if BlobUtility:IsPlayerSafe(player) then	
					local distance = (player.HumanoidRootPart.Position - pos).Magnitude

					if distance < nearestDistance then
						nearestDistance = distance
						nearestPlayer = player
					end
				end
			end
		end
	end

	if not nearestPlayer then
		return nil
	end

	return {
		Name = nearestPlayer.Name,
		Magnitude = nearestDistance,
		Player = nearestPlayer,
		Position = nearestPlayer.HumanoidRootPart.Position,
		Character = nearestPlayer,
		isDead = BlobUtility:isDead(nearestPlayer.Name)
	}
end

